# Copie este arquivo para ".env" e preencha com a connection string real do Neon.
# A connection string "pooled" (com "-pooler" no host) funciona bem tanto local
# quanto no deploy Vercel (funções serverless se beneficiam do pooler).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Nome exibido como autor das alterações no log de auditoria.
CURRENT_USER_NAME="Fernanda"

# Senha única de acesso ao sistema (tela de login). Defina algo forte antes
# de fazer deploy público — sem isso, ninguém consegue logar (senha vazia
# nunca é aceita).
APP_PASSWORD=""
